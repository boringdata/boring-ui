# boring.app.toml — Configuration for myapp

[app]
name = "myapp"
logo = "M"
id   = "myapp"

[framework]
repo   = "github.com/boringdata/boring-ui"
commit = "<commit>"

[backend]
type  = "go"
entry = "."
port  = 8000

[frontend]
port = 5173

[frontend.branding]
name = "myapp"

[frontend.features]
agentRailMode = "all"

[frontend.data]
backend = "http"

[auth]
provider       = "local"
session_cookie = "boring_session"
session_ttl    = 86400

# ─── Deploy ──────────────────────────────────────────────
[deploy]
platform = "fly"
env      = "prod"

[deploy.secrets]
ANTHROPIC_API_KEY = { vault = "secret/agent/anthropic", field = "api_key" }

# [deploy.env_vars]
# App-specific static env vars (non-secret, baked into container)
# MY_SETTING = "value"

[deploy.neon]
# Populated by 'bui neon setup'

[deploy.fly]
org               = ""
control_plane_app = "myapp"
region            = "cdg"
